# Configurações de Diretório
DATA_DIR=data
DOWNLOAD_DIR=download
SAVE_AS_CBZ=false
LIGHTPANDA_TOKEN=
LIGHTPANDA_RETRIES=

# --- Blindagem anti-ban (Cloudflare WAF) ---
# Ritmo de navegação (token bucket): rajada máxima e reabastecimento.
AB_BUCKET_CAPACITY=3          # nº de navegações que podem ocorrer em rajada
AB_REFILL_SECONDS=20          # 1 token novo a cada N s (taxa média sustentada)
AB_MIN_GAP=8                  # intervalo mínimo (s) entre navegações
AB_CHAPTER_PAUSE_MIN=20       # pausa mínima (s) entre capítulos
AB_CHAPTER_PAUSE_MAX=45       # pausa máxima (s) entre capítulos
AB_MAX_RELOADS=2             # nº máx. de reloads "Plano C" por capítulo
DOWNLOAD_RETRIES=3           # tentativas por capítulo (falha "mole")
AB_RETRY_BACKOFF=30          # base (s) do backoff exponencial entre retries
# Disjuntor: dispara ao detectar bloqueio e entra em cooldown escalonado.
AB_FAIL_THRESHOLD=3          # falhas consecutivas que abrem o circuito
AB_BLOCK_COOLDOWN=1200       # cooldown base (s) ao bloquear — dobra a cada disparo
AB_MAX_COOLDOWN=7200         # teto (s) do cooldown